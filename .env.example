# Brawl Stars API
NEXT_PUBLIC_BRAWL_STARS_API_URL=https://api.brawlstars.com/v1
BRAWL_STARS_API_TOKEN=your_brawl_stars_api_token_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Optional: Discord Webhook for alerts (future)
DISCORD_WEBHOOK_URL=optional_discord_webhook_url
